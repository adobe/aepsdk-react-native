# Copy to .env and edit. From repo root:
#   cp e2e/.env.example e2e/.env
# `wdio.*.conf.js` loads only `e2e/.env` (not the repo root `.env`).
#
# Build + e2e (recommended): from repo root run `yarn e2e:build` so the default
# APK / .app paths exist (same idea as `e2e:android:build` vs `e2e:ios:build`).

# Find device id: adb devices -l

# Pin emulator or USB device when multiple devices are connected (recommended)
# ANDROID_UDID=emulator-5554

# Optional label for Appium capabilities (does not select the device; use UDID for that)
# ANDROID_DEVICE_NAME=Pixel_8_API_34

# APK for `appium:app`:
# - If unset: uses apps/AwesomeProject/android/.../debug/app-debug.apk when that file exists
#   (build with: yarn awesomeproject:android:assembleDebug)
# - Paths can be absolute, or relative to the `e2e/` folder
# AWESOME_PROJECT_APK=/absolute/path/to/app-debug.apk

# Uncomment to disable `appium:app` and rely on an app already installed on the device
# (package/activity only — same as E2E_SKIP_APK=1 in code)
# E2E_SKIP_APK=1

# --- iOS (Appium XCUITest) ---
# List simulators: xcrun simctl list devices available
# Pin simulator when multiple are booted (recommended)
# IOS_UDID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Optional label for capabilities (pair with UDID for a specific device)
# IOS_DEVICE_NAME=iPhone 16

# Optional; omit to let Appium pick from the simulator runtime
# IOS_PLATFORM_VERSION=18.2

# .app for `appium:app`:
# - If unset: uses apps/AwesomeProject/ios/build/.../AwesomeProject.app when that path exists
#   (build with: yarn awesomeproject:ios:build)
# - Paths can be absolute, or relative to the `e2e/` folder
# AWESOME_PROJECT_APP=/absolute/path/to/AwesomeProject.app

# Rely on an app already installed on the simulator (no `appium:app`)
# E2E_SKIP_APP=1
